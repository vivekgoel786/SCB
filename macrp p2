      "id": "6832a9f3-055f-43a0-ad17-266aa620b034",
      "cell_type": "code",
      "source": "series = df['UNEMP_RATE_lead2']\n\n# ADF Test\nadf_result = adfuller(series)\nprint(f\"ADF Statistic: {adf_result[0]:.4f}\")\nprint(f\"p-value: {adf_result[1]:.4f}\")\nif adf_result[1] < 0.05:\n    print(\"✅ Series is stationary.\")\nelse:\n    print(\"❌ Series is non-stationary.\")\n\n\n\n# Ljung-Box Test\nljung_result = acorr_ljungbox(series, lags=[20], return_df=True)\nprint(ljung_result)\nif ljung_result['lb_pvalue'].iloc[0] < 0.05:\n    print(\"❌ Autocorrelation detected.\")\nelse:\n    print(\"✅ No significant autocorrelation.\")\n\n\n\n# DW Test\nDW_stat = durbin_watson(series)\nprint(f\"DW:{DW_stat:.4f}\")\n\nif abs(DW_stat-2)<=0.1:\n    print(\"✅ No significant autocorrelation.\")\nelif DW_stat<2:\n    print(\"❌ Positive autocorrelation.\")\nelse:\n    print(\"❌ Negetive autocorrelation.\")\n    \n\n\n#acf and pacf values\nacf_values = acf(series, nlags=20)\npacf_values = pacf(series, nlags=20)\n\n#plot ACF\nplot_acf(series, lags=20)\nplt.show()\nplot_pacf(series, lags=20)\nplt.show()",
