      "cell_type": "code",
      "source": "import pandas as pd\nfrom sklearn.preprocessing import StandardScaler\nimport statsmodels.api as sm\nfrom statsmodels.miscmodels.ordinal_model import OrderedModel\nfrom scipy.stats import chi2\n\ndef test_proportional_odds_multivariate(df, dependent_var='Economy_State_dummy'):\n    # Drop missing data\n    df = df.dropna()\n    if 'Date' in df.columns:\n        df = df.drop(columns=['Date'])\n\n    # Ensure dependent variable is ordered categorical\n    df[dependent_var] = pd.Categorical(df[dependent_var], ordered=True)\n\n    # Separate predictors and target\n    y_ord = df[dependent_var]\n    X = df.drop(columns=[dependent_var])\n\n    # Standardize predictors\n    scaler = StandardScaler()\n    X_scaled = pd.DataFrame(scaler.fit_transform(X), columns=X.columns, index=X.index)\n\n    # Add constant for binary logits\n    X_const = sm.add_constant(X_scaled)\n\n    # Fit proportional odds model with scaled predictors\n    model_po = OrderedModel(y_ord, X_scaled, distr='logit')\n    res_po = model_po.fit(method='bfgs', disp=False)\n\n    thresholds = y_ord.cat.categories\n    ll_unconstrained = 0\n    n_params_unconstrained = 0\n\n    # Fit separate binary logits for each threshold with scaled predictors\n    for i in range(len(thresholds) - 1):\n        y_binary = (y_ord.cat.codes <= i).astype(int)\n        logit_model = sm.Logit(y_binary, X_const).fit(disp=False)\n        ll_unconstrained += logit_model.llf\n        n_params_unconstrained += logit_model.df_model + 1  # intercept\n\n    # Likelihood Ratio Test\n    ll_po = res_po.llf\n    n_params_po = len(res_po.params)\n\n    lr_stat = 2 * (ll_unconstrained - ll_po)\n    df_diff = n_params_unconstrained - n_params_po\n    p_value = chi2.sf(lr_stat, df_diff)\n\n    results = {\n        'PO_loglikelihood': ll_po,\n        'Unconstrained_loglikelihood': ll_unconstrained,\n        'LR_statistic': lr_stat,\n        'df_diff': df_diff,\n        'p_value': p_value,\n        'Inference': 'Proportional Odds Assumption Holds' if p_value > 0.05 else 'Proportional Odds Assumption Violated'\n    }\n\n    return results",
