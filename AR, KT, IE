import pandas as pd

def get_dataset_info(df):
    # Initialize an empty list to store the information
    info_list = []
    
    # Loop through each column in the DataFrame
    for column in df.columns:
        # Get the number of observations
        total_obs = df[column].shape[0]
        
        # Get the count of missing values
        missing_count = df[column].isnull().sum()
        
        # Calculate the missing percentage
        missing_percentage = (missing_count / total_obs) * 100
        
        # Get the number of unique values
        unique_values = df[column].nunique()
        
        # Get the data type of the variable
        data_type = df[column].dtype
        
        # Append the collected info to the list
        info_list.append({
            'Variable': column,
            'Total Observations': total_obs,
            'Missing Count': missing_count,
            'Missing Percentage': missing_percentage,
            'Unique Values': unique_values,
            'Data Type': data_type
        })
    
    # Create a DataFrame from the info list
    INFO = pd.DataFrame(info_list)
    
    return INFO

