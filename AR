'''
Change the Custom Order in the below code according to the order of riskiness of the bucket, where 1 is the riskiest and 4 is the safest. Need to fill the values present in the variable we are calculating for.
'''


def calculate_accuracy_ratio(df, dependent_column, independent_column):
    # Total count and total sum of Bads for percentage calculations
    total_count = df.count()
    total_bads = df.agg(F.sum(dependent_column)).first()[0]

    # Create summary table
    summary_table = df.groupBy(independent_column).agg(
        F.count('*').alias('#Obs'),
        F.sum(dependent_column).alias('#Bads')
    )

    # Calculate Default Rate
    summary_table = summary_table.withColumn(
        'Default_Rate',
        F.when(F.col('#Obs') > 0, summary_table['#Bads'] / summary_table['#Obs']).otherwise(0)
    )

    # Calculate percentages
    summary_table = summary_table.withColumn(
        'Perc_Bads',
        summary_table['#Bads'] / total_bads
    ).withColumn(
        'Perc_Obs',
        summary_table['#Obs'] / total_count
    )

    # Change the order of rows based on riskiness of the bucket, where 1 is the riskiest and 4 is the safest
    custom_order = F.when(summary_table[independent_column] == 'Above 100', 4) \
                    .when(summary_table[independent_column] == '50-100', 3) \
                    .when(summary_table[independent_column] == '33-50', 2) \
                    .otherwise(1)

    summary_table = summary_table.withColumn('Rank', custom_order) \
                                   .orderBy('Rank')

    # Reorder columns
    summary_table = summary_table.select('Rank', independent_column, '#Obs', '#Bads', 'Default_Rate', 'Perc_Bads', 'Perc_Obs')
    
    # Define a window specification for cumulative sums
    window_spec = Window.orderBy('Rank')

    # Calculate cumulative sums
    summary_table = summary_table.withColumn('Cum_Perc_Obs', F.sum('Perc_Obs').over(window_spec)) \
                                   .withColumn('Cum_Perc_Bads', F.sum('Perc_Bads').over(window_spec)) 

    # Add lagged values for Cum_Perc_Bads and Cum_Perc_Obs
    summary_table = summary_table.withColumn('Prev_Cum_Perc_Obs', F.lag('Cum_Perc_Obs').over(window_spec)) \
                                   .withColumn('Prev_Cum_Perc_Bads', F.lag('Cum_Perc_Bads').over(window_spec)) 

    # Replace null values in the first row with 0 for lagged columns
    summary_table = summary_table.withColumn(
        'Prev_Cum_Perc_Bads',
        F.when(F.col('Prev_Cum_Perc_Bads').isNull(), 0).otherwise(F.col('Prev_Cum_Perc_Bads'))
    ).withColumn(
        'Prev_Cum_Perc_Obs',
        F.when(F.col('Prev_Cum_Perc_Obs').isNull(), 0).otherwise(F.col('Prev_Cum_Perc_Obs'))
    )

    # Calculate CAP using the trapezoidal formula
    summary_table = summary_table.withColumn(
        'CAP',
        (summary_table['Cum_Perc_Obs'] - summary_table['Prev_Cum_Perc_Obs']) * \
        (summary_table['Cum_Perc_Bads'] + summary_table['Prev_Cum_Perc_Bads']) * 0.5
    )

    # Calculate Numerator
    Numerator = summary_table.agg(F.sum('CAP')).first()[0] - 0.5

    # Calculate Denominator 
    Denominator = 0.5 * (1 - (total_bads / total_count)) 

    # Calculate Accuracy Ratio
    AR = Numerator / Denominator if Denominator != 0 else None

    # Show the results for total bads and total observations
    print(f"Total Bads: {total_bads}, Total Obs: {total_count}")
    print(f"Numerator: {Numerator}, Denominator: {Denominator}")
    print(f"Accuracy Ratio: {AR}")
    
    return summary_table






